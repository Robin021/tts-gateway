# Copy this to .env and edit before running `docker compose up -d`.

# Where vllm-omini is reachable. Since we use --network host, this
# is localhost:8091 on the same H20 box.
VLLM_OMINI_URL=http://localhost:8091

# Model name vllm-omini serves. Must match `--served-model-name` in
# the vllm container's startup args.
VLLM_OMINI_MODEL=cosyvoice3

# Default voice when client doesn't pass one. Must already be
# uploaded to vllm-omini (see scripts/upload_voices.sh).
VLLM_OMINI_VOICE=female

# Comma-separated list of accepted Bearer tokens. CHANGE BEFORE
# EXPOSING PUBLICLY. Generate with: openssl rand -hex 32
GATEWAY_AUTH_TOKEN=CHANGE_ME_BEFORE_PROD
